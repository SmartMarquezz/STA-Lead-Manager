# Firebase Client (required for app)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Google Sheets sync (free — live spreadsheet source)
# Share sheet as "Anyone with the link" → Viewer, then paste the ID from the URL (/d/SHEET_ID/edit)
# Example: https://docs.google.com/spreadsheets/d/14n5CG6sqUGbWs3d3_5G3ubrbLe6-UG6rIc3fl9UOU48/edit
NEXT_PUBLIC_GOOGLE_SHEETS_ID=

# Legacy alias
NEXT_PUBLIC_GOOGLE_DRIVE_FILE_ID=

# AI summaries (optional — built-in free summary works with no keys)
# Default: built-in pipeline summary (100% free, no API key)
# Optional upgrade: Groq free tier — https://console.groq.com (no billing card)
GROQ_API_KEY=
# Not recommended — Google now often requires prepaid billing credits:
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# AI_PROVIDER=groq

# Groq — generates follow-up email copy (free tier)
# GROQ_API_KEY is used above in AI section

# HubSpot — EASIEST: static/private app token (no redirect URLs needed)
# Copy from HubSpot app Auth tab → Access token, or Settings → Private Apps
HUBSPOT_ACCESS_TOKEN=

# HubSpot — OPTIONAL: OAuth (only if you create an OAuth app with redirect URLs)
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_FROM_EMAIL=
HUBSPOT_MARKETING_EMAIL_ID=

# Firebase Admin (optional — for npm run migrate only)
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=
