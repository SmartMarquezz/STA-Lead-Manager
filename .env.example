# Firebase Client (required for app)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Google Sheets sync (free — live spreadsheet source)
# Share sheet as "Anyone with the link" → Viewer, then paste the ID from the URL (/d/SHEET_ID/edit)
# Example: https://docs.google.com/spreadsheets/d/14n5CG6sqUGbWs3d3_5G3ubrbLe6-UG6rIc3fl9UOU48/edit
NEXT_PUBLIC_GOOGLE_SHEETS_ID=

# Legacy alias
NEXT_PUBLIC_GOOGLE_DRIVE_FILE_ID=

# AI summaries in production (server-side only — add in Vercel, not NEXT_PUBLIC)
# Recommended: Google Gemini free tier — https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional alternatives (first matching key wins when AI_PROVIDER=auto):
# GROQ_API_KEY=          # https://console.groq.com — free tier, Llama models
# OPENAI_API_KEY=        # https://platform.openai.com — paid
# AI_PROVIDER=gemini     # gemini | groq | openai | auto (default)

# Firebase Admin (optional — for npm run migrate only)
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=
